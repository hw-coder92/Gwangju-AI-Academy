   "source": [
    "from sklearn.neighbors import KNeighborsClassifier\n",
    "\n",
    "x = [[1],[2],[3],[4]] # 공부시간\n",
    "y = [0,0,1,1] # 합격 / 불합격\n",
    "\n",
    "model = KNeighborsClassifier(n_neighbors=3) # 3,5,7 홀수로 ...\n",
    "\n",
    "model.fit(x,y)\n",
    "\n",
    "result = model.predict([[2.5]])\n",
    "print(result)"
   ]
  }
 ],
